# ─── Vector DB (Qdrant Cloud) ──────────────────────────────────────────────
QDRANT_URL=https://YOUR-INSTANCE.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=legal_articles

# ─── Database (Neon Postgres) ──────────────────────────────────────────────
NEON_DATABASE_URL=postgresql+psycopg://user:pass@host/db?sslmode=require

# ─── Auth (JWT) ────────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ─── LLM (Groq — answer generation) ────────────────────────────────────────
GROQ_API_KEY_1=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_2=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_3=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# ─── LLM (Gemini — embeddings) ─────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-key
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_MODEL=gemini-2.0-flash

# ─── BM25 index path (inside container) ────────────────────────────────────
BM25_INDEX_PATH=/app/backend/data/bm25_index.pkl
HYBRID_VECTOR_WEIGHT=0.6
HYBRID_BM25_WEIGHT=0.4
MULTI_QUERY_COUNT=2
RETRIEVAL_TOP_K=12
PHAPDIEN_MAX_CONTENT_CHARS=10000
