# =========================
# Vector DB (Qdrant)
# =========================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# =========================
# LLM - Answer Generation (Groq)
# Pool 3 keys, sẽ xoay vòng khi 1 key bị rate-limit / quota.
# Nếu cả 3 hết thì backend trả fallback message.
# =========================
GROQ_API_KEY_1=your_first_groq_api_key_here
GROQ_API_KEY_2=your_second_groq_api_key_here
GROQ_API_KEY_3=your_third_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# =========================
# LLM - Embeddings (Gemini)
# =========================
# =========================
# LLM - Embeddings (Ollama, local)
# Run `ollama pull bge-m3` first.
# =========================
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=bge-m3

# =========================
# LLM - Embeddings (Gemini, fallback)
# Kept for reference, not used by RAG retrieval.
# =========================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# =========================
# Database (Neon Postgres)
# =========================
NEON_DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require

# =========================
# Auth (JWT)
# =========================
JWT_SECRET_KEY=replace_with_strong_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
